ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
# Optional. Defaults to "1". Bump to invalidate all existing admin sessions
# (log everyone out) without rotating ADMIN_SESSION_SECRET.
ADMIN_SESSION_VERSION=1

# Optional backup/restore script overrides.
BACKUP_DIR=/var/backups/harborstats
RETENTION_DAYS=30
DATABASE_NAME=harborstats
POSTGRES_USER=postgres
