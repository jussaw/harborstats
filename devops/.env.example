ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
# Optional. Defaults to "1". Bump to invalidate all existing admin sessions
# (log everyone out) without rotating ADMIN_SESSION_SECRET.
ADMIN_SESSION_VERSION=1

# Password for the internal Postgres user. The db container is not exposed
# outside the compose network, but set a real value anyway (defense in depth).
# Only applied when the data volume is first initialized — changing it later
# requires ALTER USER inside the running container (see the deploy README).
POSTGRES_PASSWORD=change-me-too

# Optional backup/restore script overrides.
BACKUP_DIR=/var/backups/harborstats
RETENTION_DAYS=30
DATABASE_NAME=harborstats
POSTGRES_USER=postgres
