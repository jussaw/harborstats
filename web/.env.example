DATABASE_URL=postgres://postgres:postgres@localhost:5432/harborstats

# Admin panel authentication
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
# Optional. Defaults to "1". Bump this to invalidate all existing admin
# sessions (log everyone out) without rotating ADMIN_SESSION_SECRET.
ADMIN_SESSION_VERSION=1
